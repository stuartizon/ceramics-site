STORE_CORS=http://localhost:8000,https://docs.medusajs.com
ADMIN_CORS=http://localhost:5173,http://localhost:9000,https://docs.medusajs.com
AUTH_CORS=http://localhost:5173,http://localhost:9000,http://localhost:8000,https://docs.medusajs.com
REDIS_URL=redis://localhost:6379
JWT_SECRET=supersecret
COOKIE_SECRET=supersecret
# Matches the postgres service in the root docker-compose.yml
DATABASE_URL=postgres://medusa:medusa@localhost:5432/medusa

DB_NAME=medusa

# S3-compatible file storage. Matches the minio service in the root
# docker-compose.yml for local dev; point these at your real provider
# (S3, R2, Spaces, etc.) in production. MinIO ignores S3_REGION, but
# production should use il-central-1 (AWS Tel Aviv) if using real S3, or the
# "eeur" location hint if using Cloudflare R2 — customers are primarily in
# Israel, so keep storage close to them.
S3_FILE_URL=http://localhost:9002/medusa-media
S3_ENDPOINT=http://localhost:9002
S3_ACCESS_KEY_ID=medusa
S3_SECRET_ACCESS_KEY=medusa-minio
S3_REGION=il-central-1
S3_BUCKET=medusa-media